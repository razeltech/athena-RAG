APP_NAME=Athena
ENVIRONMENT=dev

# Database — dev default is local SQLite (zero setup).
DATABASE_URL=sqlite+aiosqlite:///./athena.db
# For Postgres: DATABASE_URL=postgresql+asyncpg://athena:athena@localhost:5432/athena

# Auth — CHANGE THIS to a long random string
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Local LLM via Ollama (no API key, fully offline)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b-instruct
# Better answers on a 12GB GPU (slower): qwen2.5:14b-instruct-q4_K_M
LLM_TEMPERATURE=0.5
LLM_NUM_CTX=8192
# How long Ollama keeps the model resident in VRAM after the last request.
# Shorter frees GPU memory sooner for other local models (e.g. voice);
# longer avoids a reload delay on the next chat message.
LLM_KEEP_ALIVE=5m

# Local embeddings — CPU by default on purpose (small model; keeps GPU
# memory free for the LLM). Set to "cuda" only if you have GPU to spare.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Local vector store
CHROMA_DIR=./data/chroma
RETRIEVAL_TOP_K=5

# Retrieval quality (Phase 3: hybrid search + rerank)
HYBRID_CANDIDATE_K=20
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Same reasoning as EMBEDDING_DEVICE — CPU by default, GPU reserved for the LLM.
RERANKER_DEVICE=cpu

# Resource management (see docs/DECISIONS.md D-014). Leave unset to use
# torch's own default (usually all logical cores); set a number on
# lower-end/low-core-count hardware so local models don't starve the app's
# own event loop.
# CPU_THREAD_LIMIT=4

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Uploads
UPLOAD_DIR=./data/uploads
